[t:template,n:dsx_knight_death_re_summon]
{
	specializes = dsx_knight_death_base;

	doc = "[summon] dsx_knight_death";
	aspect:experience_value = 0;
    physics:explode_when_killed = false;
    [inventory]
	{
		spew_equipped_kill_count = <ignore>;
		[equipment]
		{
			es_shield_hand = sh_m_g_c_r_s_avg; // adds 7 to armor
			es_weapon_hand = ax_d_c_1h1b_avg_dsx;
			es_chest = bd_pl_f_g_c_death_knight; // adds 1 to armor
		}
		[pcontent] { /* ERASED */ }
	}
}
