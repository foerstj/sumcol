[t:template,n:drake_green_re_summon]
{
	specializes = drake_green_base;

	doc = "[summon] drake_green";
	aspect:experience_value = 0;
	[inventory]
	{
    	selected_active_location = il_active_primary_spell;
		[other] { il_active_primary_spell = spell_drake_green_breath_summon; }  // EDITED
		[pcontent]
		{
			[gold*]
			{
				chance = 0;
			}
		}
	}
}
