		sample = s_v_cf_beuwel2;
	}
	[text*]
	{
		choice = shop;
		sample = s_v_cf_beuwel3;
		screen_text = "You know the drill. Just let me know when you've found something you want.";
	}
}
[shop_demonics]
{
	[goodbye*]
	{
		sample = s_v_path2dm_bodrus2;
		screen_text = "A pleasure doing business with you.";
	}
	[text*]
	{
		choice = shop;
		sample = s_v_path2dm_bodrus3;
		screen_text = "Ahh! How good to see you again! Is there some magical artifact you might bear to part with?";
	}
}
